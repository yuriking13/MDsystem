{
  "name": "thesis-stack",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.js",
    "quality:guards": "node scripts/quality-guards.js",
    "quality:guards:check": "node scripts/quality-guards.js --check",
    "quality:guards:test": "node scripts/run-quality-guards-tests.mjs",
    "quality:repo": "pnpm run quality:guards:check && pnpm run quality:guards:test",
    "prisma:generate": "pnpm --filter api exec prisma generate",
    "clean:js-mirrors": "pnpm --filter web run clean:js-mirrors",
    "check:js-mirrors": "pnpm --filter web run check:js-mirrors",
    "dev": "pnpm -r dev",
    "build": "pnpm run quality:repo && pnpm run prisma:generate && pnpm -r build",
    "build:ci": "pnpm run prisma:generate && pnpm -r build",
    "lint": "pnpm run quality:repo && pnpm run prisma:generate && pnpm -r run lint",
    "lint:fix": "pnpm run quality:repo && pnpm -r run lint:fix",
    "typecheck": "pnpm run quality:repo && pnpm run prisma:generate && pnpm -r run typecheck",
    "test": "pnpm run quality:repo && pnpm run prisma:generate && pnpm -r run test",
    "test:responsive": "pnpm run quality:repo && pnpm --filter web run test:responsive",
    "test:coverage": "pnpm run quality:repo && pnpm run prisma:generate && pnpm -r run test:coverage",
    "perf:api:smoke": "node scripts/perf/basic-load-smoke.mjs",
    "e2e:smoke": "node scripts/e2e/critical-flows-smoke.mjs",
    "e2e:browser": "pnpm --filter web run e2e",
    "e2e:browser:install": "pnpm --filter web run e2e:install",
    "prepare": "husky || true",
    "db:cleanup": "cd apps/api && node -e \"require('child_process').execSync('psql ' + process.env.DATABASE_URL + ' -f prisma/migrations/cleanup_invalid_statistics.sql', {stdio: 'inherit'})\"",
    "start": "node apps/api/dist/src/bootstrap.js"
  },
  "dependencies": {
    "@tiptap/extension-paragraph": "^3.14.0",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.4",
    "tiptap-pagination-plus": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*": [
      "pnpm run quality:guards:check"
    ],
    "scripts/*.js": [
      "pnpm run quality:guards:test"
    ],
    "apps/web/scripts/*.{js,mjs,cjs}": [
      "pnpm run quality:guards:test"
    ],
    "*.{ts,tsx}": [
      "prettier --write --ignore-unknown"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "@remix-run/router": "^1.23.2",
      "ajv": "^8.18.0",
      "esbuild": "^0.25.0",
      "fast-xml-parser": "^5.3.6",
      "markdown-it": "^14.1.1",
      "minimatch": "^10.2.4",
      "preact": "^10.28.3",
      "qs": "^6.14.2",
      "bn.js@<4.12.3": ">=4.12.3",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=10.0.0 <10.2.4": ">=10.2.4",
      "underscore@<=1.13.7": ">=1.13.8",
      "dompurify@>=3.1.3 <=3.3.1": ">=3.3.2",
      "fast-xml-parser@>=5.0.0 <5.3.8": ">=5.3.8",
      "fastify@>=5.7.2 <=5.8.0": ">=5.8.1",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "flatted@<3.4.0": ">=3.4.0",
      "file-type@>=20.0.0 <=21.3.1": ">=21.3.2",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.5": ">=5.5.6"
    },
    "patchedDependencies": {
      "@eslint/eslintrc@3.3.3": "patches/@eslint__eslintrc@3.3.3.patch",
      "eslint@9.39.2": "patches/eslint@9.39.2.patch"
    }
  }
}
